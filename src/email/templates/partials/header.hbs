<table
  width='800px'
  align='center'
  border='0'
  cellspacing='0'
  cellpadding='0'
  style='padding:0;'
>

  <!-- LOGO -->
  <tr>
    <td style='width:300px; padding:30px 0; text-align:left;'>
      <a href='https://zurawickidesign.pl/' target='_blank'>
        <img
          src='{{ASSETS_URL}}/logo-black.png'
          alt='logo'
          width='300'
          style='display:block; width:300px; max-width:300px;'
          border='0'
        />
      </a>
    </td>
    <td style='width: 500px;'></td>
  </tr>

  <!-- TITLE -->
  <tr>
    <td style='padding:0; text-align:left;' colspan='2'>
      <h2
        style='margin:0; padding:0 0 10px 0; font-size:16px; font-weight:bold;'
      >
        {{HTMLheader}}
      </h2>
    </td>
  </tr>
  <tr>
    <td
      style='padding:0 0 10px 0; line-height:1.6; font-size:16px;'
      colspan='2'
    >
      <p>Dzień dobry.</p>
    </td>
  </tr>
</table>